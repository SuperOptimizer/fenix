{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 29, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "toolchainFile": "${sourceDir}/cmake/clang-toolchain.cmake",
      "binaryDir": "${sourceDir}/build-${presetName}",
      "cacheVariables": { "CMAKE_EXPORT_COMPILE_COMMANDS": "ON" }
    },
    {
      "name": "release",
      "inherits": "base",
      "displayName": "Release (-Ofast/native, fast-by-default)",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release", "FENIX_FAST": "ON" }
    },
    {
      "name": "split",
      "inherits": "release",
      "displayName": "Split dev build (one TU per module, parallel + incremental, ccache)",
      "cacheVariables": { "FENIX_SPLIT": "ON", "FENIX_TEST_OPT": "-O1" }
    },
    {
      "name": "ml",
      "inherits": "release",
      "displayName": "ML split build (libtorch isolated to one TU; driver stays torch-free)",
      "cacheVariables": { "FENIX_ML": "ON", "FENIX_SPLIT": "ON", "FENIX_TEST_OPT": "-O1" }
    },
    {
      "name": "gui",
      "inherits": "release",
      "displayName": "GUI build (Qt6 4-pane viewer + annotator; -DFENIX_GUI=ON)",
      "cacheVariables": { "FENIX_GUI": "ON" }
    },
    {
      "name": "relwithdebinfo",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "RelWithDebInfo" }
    },
    {
      "name": "debug",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "FENIX_FAST": "OFF" }
    },
    {
      "name": "asan",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "FENIX_FAST": "OFF", "FENIX_SANITIZE": "address;undefined" }
    },
    {
      "name": "ubsan",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "FENIX_FAST": "OFF", "FENIX_SANITIZE": "undefined" }
    },
    {
      "name": "tsan",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "FENIX_FAST": "OFF", "FENIX_SANITIZE": "thread" }
    },
    {
      "name": "msan",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "FENIX_FAST": "OFF", "FENIX_SANITIZE": "memory" }
    },
    {
      "name": "coverage",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "FENIX_FAST": "OFF", "FENIX_COVERAGE": "ON" }
    },
    {
      "name": "fuzz",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "FENIX_FAST": "OFF", "FENIX_SANITIZE": "address", "FENIX_FUZZ": "ON" }
    },
    {
      "name": "profiling",
      "inherits": "relwithdebinfo",
      "cacheVariables": { "CMAKE_CXX_FLAGS": "-fno-omit-frame-pointer" }
    }
  ],
  "buildPresets": [
    { "name": "release", "configurePreset": "release" },
    { "name": "gui", "configurePreset": "gui" },
    { "name": "split", "configurePreset": "split" },
    { "name": "ml", "configurePreset": "ml" },
    { "name": "debug", "configurePreset": "debug" },
    { "name": "asan", "configurePreset": "asan" },
    { "name": "ubsan", "configurePreset": "ubsan" },
    { "name": "tsan", "configurePreset": "tsan" },
    { "name": "msan", "configurePreset": "msan" },
    { "name": "coverage", "configurePreset": "coverage" },
    { "name": "fuzz", "configurePreset": "fuzz" }
  ],
  "testPresets": [
    { "name": "release", "configurePreset": "release", "output": { "outputOnFailure": true } },
    { "name": "debug", "configurePreset": "debug", "output": { "outputOnFailure": true } },
    { "name": "asan", "configurePreset": "asan", "output": { "outputOnFailure": true } }
  ]
}
